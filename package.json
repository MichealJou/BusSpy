{
  "name": "busspy",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "desktop:dev": "pnpm --filter @busspy/desktop dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "tauri": "pnpm --filter @busspy/desktop tauri",
